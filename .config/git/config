[core]
  editor = "nvim -c '1 | startinsert!'"
  pager = delta

[user]
  name = Caleb Spare
  email = cespare@gmail.com

[diff]
  tool = vimdiff
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true

[column]
	ui = auto

[alias]
  s = status --short --branch --ignore-submodules=untracked
  c = commit
  a = add
  sn = status --short --branch --untracked=no
  sw = switch
  wc = log --name-status
  l = log
  b = branch
  sub = submodule
  t = tag
  w = worktree
  p = pull --quiet
  root = rev-parse --show-toplevel
  su = !"cd `git root` && git sub update --init --recursive && cd -"
  ff = merge --ff-only
  pf = push --force-with-lease
  pfb = "!f() { \
      u=$(git rev-parse --abbrev-ref \"$1@{upstream}\") || exit 1; \
      git push --force-with-lease \"${u%%/*}\" \"$1:${u#*/}\"; \
    }; f"
  ls = ls-files
  bi = bisect
  h = rev-parse HEAD
  r = rebase
  ri = rebase -i
  # rebase from the merge base of the given branch and HEAD.
  rif = "!git rebase -i $(git merge-base \"$1\" HEAD) #"
  cp = cherry-pick
  dc = diff --cached
  lol = log --oneline --graph --decorate
  oneline = log --format='%C(auto) %h %s'
  conf = config
  cam = commit -a --amend
  whoami = config --get user.email
  conflicts = diff --name-only --diff-filter=U
  fza = "!git ls-files -m -o --exclude-standard | fzf --print0 -m | xargs -0 -t -o git add"
  wip-remote = for-each-ref --sort='-committerdate:iso8601' --count 20 --format=' %(color:green)%(committerdate:relative)%09%(color:white)%(refname:short)' refs/remotes/origin
  wip = for-each-ref --sort='-authordate:iso8601' --count 20 --format=' %(color:green)%(authordate:relative)%09%(color:white)%(refname:short)' refs/heads
  rmain = "!f() { \
      b=$(git rev-parse --abbrev-ref origin/HEAD | cut -d/ -f2-); \
      git fetch origin \"$b\" && git rebase \"origin/$b\"; \
    }; f"

  # For Go development.
  change = codereview change
  gofmt = codereview gofmt
  mail = codereview mail -trust
  pending = codereview pending
  submit = codereview submit
  sync = codereview sync

[branch]
  autoSetupRebase = always
  sort = committerdate

[tag]
  sort = version:refname

[commit]
  verbose = true

[merge]
  conflictStyle = zdiff3

[fetch]
  prune = true
  pruneTags = true

[push]
  autoSetupRemote = true
  followTags = true

[pull]
  rebase = true

[rebase]
  autoSquash = true
  updateRefs = true

[init]
  defaultBranch = main

[color]
  diff = auto
  status = auto
  branch = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[delta]
  navigate = true
  side-by-side = 160
  dark = true
  hyperlinks = true
  syntax-theme = cespare
  wrap-max-lines = unlimited
  wrap-right-percent = 1

  file-added-label = [+]
  file-copied-label = [==]
  file-modified-label = [M]
  file-removed-label = [-]
  file-renamed-label = [->]
  file-style = bold
  file-decoration-style = ul
  hunk-header-decoration-style = "#555555" ul
  hunk-header-file-style = bold
  hunk-header-line-number-style = "#5c8ec9" normal
  hunk-header-style = line-number syntax bold
  line-numbers = true
  line-numbers-left-format = "{nm:>1}│"
  line-numbers-right-format = "{np:>1}│"
  line-numbers-left-style = "#555555" normal
  line-numbers-right-style = "#555555" normal
  line-numbers-zero-style = "#8a8a8a"
  line-numbers-minus-style = "#ff6b6b"
  line-numbers-plus-style = "#6ee06e"

  # These are delta's dark-theme hunk background defaults.
  minus-style = syntax "#3f0001"
  minus-non-emph-style = minus-style
  minus-emph-style = syntax "#901011"
  minus-empty-line-marker-style = normal "#3f0001"
  plus-style = syntax "#002800"
  plus-non-emph-style = plus-style
  plus-emph-style = syntax "#006000"
  plus-empty-line-marker-style = normal "#002800"

  # For colorMoved.
  # Include normal here because git doesn't properly color leading tabs of
  # moved-to blocks.
  map-styles = \
    normal => syntax "#0d3531", \
    bold purple => syntax "#330f29", \
    bold blue => syntax "#271344", \
    bold cyan => syntax "#0d3531", \
    bold yellow => syntax "#222f14"

[interactive]
  diffFilter = delta --color-only

[github]
  user = cespare

# Put OS-specific stuff in .gitconfig.local.
[include]
  path = ~/.gitconfig.local
